{
	"name": "angular-hono-worker",
	"version": "0.0.0",
	"scripts": {
		"ng": "ng",
		"start": "ng serve",
		"build": "ng build",
		"watch": "ng build --watch --configuration development",
		"test": "ng test",
		"serve:ssr:angular-hono-worker": "node dist/angular-hono-worker/server/server.mjs",
		"preview": "pnpm run build && wrangler dev",
		"deploy": "pnpm run build && wrangler deploy",
		"cf-typegen": "wrangler types"
	},
	"prettier": {
		"printWidth": 100,
		"singleQuote": true,
		"overrides": [
			{
				"files": "*.html",
				"options": {
					"parser": "angular"
				}
			}
		]
	},
	"private": true,
	"packageManager": "pnpm@10.25.0",
	"dependencies": {
		"@angular/common": "^21.0.0",
		"@angular/compiler": "^21.0.0",
		"@angular/core": "^21.0.0",
		"@angular/forms": "^21.0.0",
		"@angular/platform-browser": "^21.0.0",
		"@angular/platform-server": "^21.0.0",
		"@angular/router": "^21.0.0",
		"@angular/ssr": "^21.0.1",
		"@hono/standard-validator": "^0.2.0",
		"@valibot/to-json-schema": "^1.5.0",
		"hono": "^4.11.0",
		"hono-openapi": "^1.1.2",
		"rxjs": "~7.8.0",
		"tslib": "^2.3.0",
		"valibot": "^1.2.0"
	},
	"devDependencies": {
		"@angular/build": "^21.0.1",
		"@angular/cli": "^21.0.1",
		"@angular/compiler-cli": "^21.0.0",
		"@types/node": "^20.17.19",
		"jsdom": "^27.1.0",
		"typescript": "~5.9.2",
		"vitest": "^4.0.8",
		"wrangler": "^4.53.0",
		"xhr2": "^0.2.1"
	}
}